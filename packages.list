# Source of truth for packages to mirror and include in the ISO.
# Edit this file to add/remove packages, then re-run build.sh.
#
# Syntax:
#   -pkg    → exclude this package (e.g. -kernel to force kernel-rt)
#   pkg     → individual package
#
# Note: @^minimal-environment is not resolvable via --repofrompath.
# Equivalent packages are listed explicitly below.

## TUI network management
NetworkManager-tui
newt
slang

## Base system (equivalent to @^minimal-environment / @core)
## These packages would normally be installed by the group but must be
## listed explicitly for dnf download dependency resolution.
basesystem
filesystem
setup
bash
coreutils
shadow-utils
passwd
rootfiles
glibc
systemd
dbus
NetworkManager
iproute
iputils
hostname
openssh-server
openssh-clients
curl-minimal
firewalld
audit
selinux-policy-targeted
policycoreutils
authselect
crypto-policies
dracut
initscripts
grub2-tools
grubby
e2fsprogs
lvm2
xfsprogs
parted
util-linux
procps-ng
less
man-db
ncurses
vim-enhanced
tar
kbd
kexec-tools
rsyslog
logrotate
cronie
tuned
sudo
sssd-common
python3
dnf
rpm
sssd-common
libsss_sudo
nvme-cli
grub2-efi-x64
shim-x64
efibootmgr
chrony

## Real-time kernel (replaces the standard kernel)
-kernel
-kernel-core
-kernel-modules
-kernel-modules-extra
kernel-rt
kernel-rt-core
kernel-rt-devel
kernel-rt-modules-extra

